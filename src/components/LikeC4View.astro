---
import { LikeC4View as ReactLikeC4View, type LikeC4ViewId } from 'likec4:react';

interface Props {
  viewId: LikeC4ViewId;
}

const { viewId } = Astro.props;
---

<ReactLikeC4View
  viewId={viewId}
  controls={true}
  browser={{
    enableFocusMode: true,
    enableSearch: false,
  }}
  client:only="react"
/>
